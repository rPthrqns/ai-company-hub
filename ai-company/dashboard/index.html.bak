};

let currentLang = localStorage.getItem('hub-lang') || 'ko';
const t = key => (UI[currentLang] || UI.ko)[key] || key;

function applyLang() {
  const u = UI[currentLang];
  document.querySelector('.create-btn') && (document.querySelector('.create-btn').textContent = u.createBtn);
  document.getElementById('empty-state') && (() => {
    const es = document.getElementById('empty-state');
    es.querySelector('p').textContent = u.emptyTitle;
    es.querySelector('.hint').textContent = u.emptyHint;
    const btn = es.querySelector('.create-btn');
    if(btn) btn.textContent = u.emptyBtn;
  })();
}

function setLang(lang) {
  currentLang = lang;
  localStorage.setItem('hub-lang', lang);
  document.getElementById('lang-screen').style.display = 'none';
  document.getElementById('app').style.display = '';
  applyLang();
}

// Show lang screen if no preference
if (localStorage.getItem('hub-lang')) {
  document.getElementById('lang-screen').style.display = 'none';
  document.getElementById('app').style.display = '';
} else {
  document.getElementById('lang-screen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}
</script>
</body>
</html>
