<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Company Hub</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a1a;--panel:#111827;--card:#1e293b;--border:#1e3a5f;--text:#e0e0e0;--dim:#64748b;--accent:#3b82f6;--accent2:#8b5cf6;--green:#00ff88;--yellow:#fbbf24}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);height:100vh;overflow:hidden}
.header{background:linear-gradient(135deg,#1a1a2e,#16213e);padding:14px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.header h1{font-size:20px}.header h1 span{color:#7b68ee}
.header .sub{font-size:11px;color:var(--dim);margin-top:1px}
.hdr-right{display:flex;gap:10px;align-items:center}

/* Top bar: company selector + create */
.toolbar{background:#0d1117;padding:10px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px}
.company-tabs{display:flex;gap:6px;flex:1;overflow-x:auto}
.company-tab{background:var(--card);border:1px solid transparent;border-radius:8px;padding:6px 14px;font-size:12px;color:var(--dim);cursor:pointer;white-space:nowrap;transition:all .15s;display:flex;align-items:center;gap:6px}
.company-tab:hover{border-color:var(--accent);color:var(--text)}
.company-tab.active{background:#1e3a5f;border-color:var(--accent);color:white}
.company-tab .dot{width:6px;height:6px;border-radius:50%;background:var(--green)}
.create-btn{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border:none;padding:7px 16px;border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;white-space:nowrap}

/* Main layout */
.main{display:grid;grid-template-columns:220px 1fr 240px;gap:14px;padding:14px 24px;height:calc(100vh - 105px)}

.panel{background:var(--panel);border-radius:12px;padding:14px;border:1px solid #1e293b;display:flex;flex-direction:column;overflow:hidden}
.panel-title{font-size:12px;font-weight:600;color:var(--dim);margin-bottom:10px;display:flex;align-items:center;gap:5px}

/* Org */
.agent-card{background:var(--card);border-radius:8px;padding:9px;margin-bottom:5px;transition:all .15s;border-left:3px solid #4b5563;cursor:pointer}
.agent-card:hover{background:#253047;transform:translateX(2px)}
.agent-card.active{border-left-color:var(--green)}.agent-card.working{border-left-color:var(--yellow)}.agent-card.idle{opacity:.5}
.agent-top{display:flex;align-items:center;gap:6px}
.agent-emoji{font-size:16px}.agent-name{font-size:12px;font-weight:600;color:#f1f5f9}
.agent-role{font-size:9px;color:var(--dim);margin-top:1px}
.agent-meta{display:flex;justify-content:space-between;margin-top:4px;font-size:9px;color:var(--dim)}
.agent-tag{font-size:8px;padding:1px 6px;border-radius:6px}
.agent-tag.active{background:#064e3b;color:#6ee7b7}
.agent-tag.working{background:#78350f;color:#fcd34d}
.agent-tag.idle{background:#1f2937;color:#9ca3af}
.pbar{height:2px;background:#374151;border-radius:2px;margin-top:4px;overflow:hidden}
.pfill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;transition:width .5s}

/* Chat center */
.chat-panel{display:flex;flex-direction:column}
.mentions{display:flex;gap:4px;margin-bottom:8px;flex-wrap:wrap}
.mention-btn{background:var(--card);border:1px solid #374151;border-radius:6px;padding:3px 8px;font-size:10px;color:var(--dim);cursor:pointer;display:flex;align-items:center;gap:3px;transition:all .1s}
.mention-btn:hover{border-color:var(--accent);color:var(--text)}
.chat-messages{flex:1;overflow-y:auto;padding:6px 0;display:flex;flex-direction:column}
.chat-msg{display:flex;gap:7px;margin-bottom:7px;animation:fadeIn .2s;max-width:80%}
.chat-msg.user{align-self:flex-end;flex-direction:row-reverse}
.chat-msg .avatar{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.chat-msg.agent .avatar{background:var(--card)}
.chat-msg.user .avatar{background:#1e3a5f}
.chat-body{display:flex;flex-direction:column}
.chat-msg.user .chat-body{align-items:flex-end}
.chat-sender{font-size:9px;color:var(--dim);font-weight:600}
.chat-bubble{padding:7px 11px;border-radius:10px;font-size:12px;color:#e2e8f0;line-height:1.5;white-space:pre-wrap}
.chat-msg.agent .chat-bubble{background:var(--card);border:1px solid #2d3748;border-radius:3px 10px 10px 10px}
.chat-msg.user .chat-bubble{background:#1e3a5f;border-radius:10px 3px 10px 10px}
.chat-bubble .mention{color:#60a5fa;font-weight:600}
.chat-input-area{display:flex;gap:7px;margin-top:8px;flex-shrink:0}
.chat-input{flex:1;background:var(--card);border:1px solid #374151;border-radius:8px;padding:9px 12px;color:var(--text);font-size:12px;outline:none}
.chat-input:focus{border-color:var(--accent)}
.chat-input::placeholder{color:#4b5563}
.chat-send{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border:none;padding:9px 16px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px;flex-shrink:0}
.chat-send:hover{opacity:.85}
.chat-send:disabled{opacity:.4;cursor:not-allowed}
.typing{display:none;padding:3px 0;font-size:10px;color:var(--dim);flex-shrink:0}
.typing.show{display:flex;align-items:center;gap:4px}
.td span{width:3px;height:3px;background:var(--dim);border-radius:50%;display:inline-block;animation:blink 1.4s infinite}
.td span:nth-child(2){animation-delay:.2s}.td span:nth-child(3){animation-delay:.4s}
@keyframes blink{0%,100%{opacity:.3}50%{opacity:1}}

/* Tasks + Log */
.task-item{background:var(--card);border-radius:7px;padding:7px 9px;margin-bottom:4px}
.task-title{font-size:11px;color:#e2e8f0;display:flex;align-items:center;gap:4px}
.task-badge{font-size:8px;padding:1px 5px;border-radius:5px;font-weight:600}
.task-badge.completed{background:#064e3b;color:#6ee7b7}
.task-badge.in-progress{background:#78350f;color:#fcd34d}
.task-badge.pending{background:var(--card);color:var(--dim);border:1px solid #374151}
.task-assignee{font-size:9px;color:var(--dim);margin-top:2px}
.log-item{display:flex;gap:6px;padding:5px 0;border-bottom:1px solid #1a1a2e;font-size:10px;animation:fadeIn .2s}
.log-avatar{width:22px;height:22px;border-radius:50%;background:var(--card);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0}
.log-agent{font-size:10px;font-weight:600;color:#60a5fa}
.log-text{font-size:10px;color:#cbd5e1;line-height:1.3}
.log-time{font-size:8px;color:#4b5563}

/* Modal */
.modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.7);z-index:100;align-items:center;justify-content:center}
.modal-overlay.show{display:flex}
.modal{background:var(--panel);border:1px solid var(--border);border-radius:16px;padding:24px;width:420px;max-width:90vw}
.modal h2{font-size:18px;margin-bottom:16px;color:#00d4ff}
.modal label{font-size:12px;color:var(--dim);display:block;margin-bottom:4px;margin-top:12px}
.modal input,.modal select{width:100%;background:var(--card);border:1px solid #374151;border-radius:8px;padding:9px 12px;color:var(--text);font-size:13px;outline:none}
.modal input:focus,.modal select:focus{border-color:var(--accent)}
.modal-actions{display:flex;gap:8px;margin-top:20px;justify-content:flex-end}
.modal-cancel{background:var(--card);border:1px solid #374151;color:var(--dim);padding:8px 16px;border-radius:8px;cursor:pointer;font-size:13px}
.modal-submit{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border:none;padding:8px 20px;border-radius:8px;cursor:pointer;font-weight:600;font-size:13px}
.topic-suggestions{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.topic-chip{background:var(--card);border:1px solid #374151;border-radius:6px;padding:4px 10px;font-size:11px;color:var(--dim);cursor:pointer}
.topic-chip:hover,.topic-chip.selected{border-color:var(--accent);color:var(--text)}

@keyframes fadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:#374151;border-radius:2px}
.empty-state{text-align:center;padding:40px;color:var(--dim)}
.empty-state .emoji{font-size:48px;margin-bottom:12px}
.empty-state p{font-size:14px;margin-bottom:4px}
.empty-state .hint{font-size:12px}
.lang-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 8px 24px rgba(59,130,246,.2)}
.lang-switch{display:flex;gap:2px;background:var(--card);border-radius:8px;padding:2px}
.lang-btn{background:transparent;border:none;padding:4px 8px;border-radius:6px;cursor:pointer;font-size:14px;transition:all .15s}
.lang-btn:hover{background:#253047}
.lang-btn.active{background:var(--accent);color:white}
[data-i18n]{transition:opacity .15s}
</style>
</head>
<body>

<div id="lang-screen" style="display:none">

<div class="header">
  <div>
    <h1>🏢 <span>AI Company Hub</span></h1>
    <div class="sub">Multi-company AI Agent Management Platform</div>
  </div>
  <div class="hdr-right">
    <div class="lang-switch" id="lang-switch"></div>
    <div style="display:flex;align-items:center;gap:5px;background:#0f3460;padding:5px 12px;border-radius:16px;font-size:11px">
      <span style="width:6px;height:6px;border-radius:50%;background:var(--green)"></span> <span data-i18n="operating">운영 중</span>
    </div>
  </div>
</div>

<div class="toolbar">
  <div class="company-tabs" id="company-tabs"></div>
  <button class="create-btn" onclick="openModal()">＋ 새 회사</button>
</div>

<!-- Empty state -->
<div id="empty-state" class="empty-state" style="display:none">
  <div class="emoji">🏢</div>
  <p>아직 회사가 없습니다</p>
  <p class="hint">아래 버튼을 눌러 AI 회사를 시작하세요</p>
  <button class="create-btn" style="margin-top:20px;font-size:14px;padding:10px 28px" onclick="openModal()">＋ 새 회사 만들기</button>
</div>

<!-- Main (hidden until company selected) -->
<div class="main" id="main-content" style="display:none">
  <div class="panel">
    <div class="panel-title">👥 조직</div>
    <div id="org-list" style="overflow-y:auto;flex:1"></div>
  </div>
  <div class="panel chat-panel">
    <div class="panel-title" id="chat-title">💬 소통</div>
    <div class="mentions" id="mentions"></div>
    <div class="chat-messages" id="chat-messages"></div>
    <div class="typing" id="typing"><div class="td"><span></span><span></span><span></span></div> <span id="typing-who">처리 중...</span></div>
    <div class="chat-input-area">
      <input class="chat-input" id="chat-input" placeholder="@멘션으로 에이전트에게 지시" />
      <button class="chat-send" id="chat-send" onclick="sendChat()">전송</button>
    </div>
  </div>
  <div class="panel">
    <div class="panel-title">📌 작업</div>
    <div id="task-list" style="overflow-y:auto;flex:1"></div>
    <div class="panel-title" style="margin-top:12px">📋 로그</div>
    <div id="activity-list" style="overflow-y:auto;flex:1"></div>
  </div>
</div>

<!-- Create Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h2>🏢 새 회사 만들기</h2>
    <label>회사명 / 프로젝트명</label>
    <input id="m-name" placeholder="예: 마케팅 프로젝트" />
    <label>주제 / 목표</label>
    <input id="m-topic" placeholder="예:  이커머스 운영..." />
    <div class="topic-suggestions">
      <div class="topic-chip" onclick="setTopic('온라인 비즈니스')">온라인 비즈니스</div>
      <div class="topic-chip" onclick="setTopic('e-commerce 운영')">e-commerce</div>
      <div class="topic-chip" onclick="setTopic('웹 서비스 개발')">웹 개발</div>
      <div class="topic-chip" onclick="setTopic('레스토랑 홍보')">레스토랑</div>
      <div class="topic-chip" onclick="setTopic('교육 플랫폼')">교육</div>
      <div class="topic-chip" onclick="setTopic('부동산 마케팅')">부동산</div>
    </div>
    <label>언어 / Language</label>
    <select id="m-lang">
      <option value="ko">🇰🇷 한국어</option>
      <option value="en">🇺🇸 English</option>
      <option value="ja">🇯🇵 日本語</option>
      <option value="zh">🇨🇳 中文</option>
    </select>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeModal()">취소</button>
      <button class="modal-submit" onclick="createCompany()">생성</button>
    </div>
  </div>
</div>

<script>
let companies = [];
let currentCompany = null;

async function load() {
  const res = await fetch('/api/companies');
  companies = await res.json();
  renderTabs();
  if (companies.length === 0) {
    document.getElementById('empty-state').style.display = '';
    document.getElementById('main-content').style.display = 'none';
    document.querySelector('.toolbar').style.display = 'none';
  } else {
    document.getElementById('empty-state').style.display = 'none';
    document.getElementById('main-content').style.display = '';
    document.querySelector('.toolbar').style.display = '';
    if (!currentCompany || !companies.find(c=>c.id===currentCompany)) {
      selectCompany(companies[0].id);
    } else {
      refreshCompany();
    }
  }
}

function renderTabs() {
  document.getElementById('company-tabs').innerHTML = companies.map(c =>
    `<div class="company-tab ${c.id===currentCompany?'active':''}" onclick="selectCompany('${c.id}')">
      <span class="dot"></span>${c.name}
    </div>`
  ).join('');
}

async function selectCompany(cid) {
  currentCompany = cid;
  renderTabs();
  const res = await fetch(`/api/company/${cid}`);
  const company = await res.json();
  renderCompany(company);
}

async function refreshCompany() {
  if (!currentCompany) return;
  const res = await fetch(`/api/company/${currentCompany}`);
  const company = await res.json();
  renderCompany(company);
}

let lastChatLen = 0;
function renderCompany(c) {
  document.getElementById('chat-title').textContent = `💬 ${c.name}`;

  // Mentions
  document.getElementById('mentions').innerHTML = c.agents.map(a =>
    `<div class="mention-btn" onclick="insertMention('${a.name}')">${a.emoji} @${a.name}</div>`
  ).join('');

  // Org
  document.getElementById('org-list').innerHTML = c.agents.map(a => {
    const tasks = a.tasks||[];
    const done = tasks.filter(t=>t.status==='completed').length;
    const total = tasks.length;
    const prog = total ? Math.round(done/total*100) : 0;
    const hasActive = tasks.some(t=>t.status==='in-progress');
    const cls = a.status==='idle'?'idle':hasActive?'working':'active';
    const lbl = cls==='working'?'작업중':cls==='active'?'활성':'대기';
    return `<div class="agent-card ${cls}">
      <div class="agent-top"><span class="agent-emoji">${a.emoji}</span><span class="agent-name">${a.name}</span></div>
      <div class="agent-role">${a.role}</div>
      <div class="agent-meta"><span>${done}/${total}</span><span class="agent-tag ${cls}">${lbl}</span></div>
      ${total?`<div class="pbar"><div class="pfill" style="width:${prog}%"></div></div>`:''}
    </div>`;
  }).join('');

  // Tasks
  const allTasks = c.agents.flatMap(a=>(a.tasks||[]).map(t=>({...t,agent:a})));
  document.getElementById('task-list').innerHTML = allTasks.length ? allTasks.map(t=>{
    const cls=t.status==='completed'?'completed':t.status==='in-progress'?'in-progress':'pending';
    const lbl=t.status==='completed'?'완료':t.status==='in-progress'?'진행중':'대기';
    return `<div class="task-item"><div class="task-title">${t.title} <span class="task-badge ${cls}">${lbl}</span></div><div class="task-assignee">${t.agent.emoji} ${t.agent.name}</div></div>`;
  }).join('') : '<div style="color:var(--dim);text-align:center;padding:14px;font-size:10px">대기 중</div>';

  // Activity
  document.getElementById('activity-list').innerHTML = (c.activity_log||[]).slice().reverse().slice(0,20).map(a=>{
    const agent=c.agents.find(x=>x.id===a.agent);
    const emoji=agent?agent.emoji:(a.agent==='마스터'?'👤':'🤖');
    return `<div class="log-item"><div class="log-avatar">${emoji}</div><div><div class="log-agent">${a.agent}</div><div class="log-text">${a.text}</div><div class="log-time">${a.time}</div></div></div>`;
  }).join('');

  // Chat - only new messages
  if (c.chat && c.chat.length > lastChatLen) {
    const newMsgs = c.chat.slice(lastChatLen);
    lastChatLen = c.chat.length;
    newMsgs.forEach(m => appendChat(m));
    if (newMsgs.some(m=>m.type==='agent')) document.getElementById('typing').classList.remove('show');
  } else if (c.chat) {
    lastChatLen = c.chat.length;
  }
}

function appendChat(m) {
  const el = document.getElementById('chat-messages');
  const isUser = m.type==='user';
  const avatar = isUser?'👤':(m.emoji||'👔');
  el.innerHTML += `<div class="chat-msg ${isUser?'user':'agent'}">
    <div class="avatar">${avatar}</div>
    <div class="chat-body"><div class="chat-sender">${m.from}</div><div class="chat-bubble">${(m.text||'').replace(/@(\w+)/g,'<span class="mention">@$1</span>')}</div></div>
  </div>`;
  el.scrollTop = el.scrollHeight;
}

function insertMention(name) {
  const i=document.getElementById('chat-input');
  i.value+='@'+name+' ';i.focus();
}

async function sendChat() {
  const input=document.getElementById('chat-input');
  const text=input.value.trim();if(!text)return;
  input.value='';
  document.getElementById('chat-send').disabled=true;
  try{
    const res=await fetch(`/api/chat/${currentCompany}`,{
      method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text})
    });
    const data=await res.json();
    if(data.ok){
      lastChatLen++;
      appendChat(data.msg);
      document.getElementById('typing-who').textContent=data.target+' 처리 중...';
      document.getElementById('typing').classList.add('show');
    }
  }catch(e){alert('전송 실패')}
  document.getElementById('chat-send').disabled=false;
}

document.getElementById('chat-input').addEventListener('keydown',e=>{
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat()}
});

function openModal(){document.getElementById('modal').classList.add('show')}
function closeModal(){document.getElementById('modal').classList.remove('show')}
function setTopic(t){document.getElementById('m-topic').value=t}

async function createCompany(){
  const name=document.getElementById('m-name').value.trim();
  const topic=document.getElementById('m-topic').value.trim();
  const lang=document.getElementById('m-lang').value;
  if(!name||!topic){alert('회사명과 주제를 입력하세요');return}
  const res=await fetch('/api/companies',{
    method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,topic,lang})
  });
  const data=await res.json();
  if(data.ok){closeModal();currentCompany=data.company.id;load()}
}

load();
setInterval(refreshCompany, 3000);

// Language screen
const UI = {
  ko: {newCompany:'새 회사',createBtn:'＋ 새 회사',emptyTitle:'아직 회사가 없습니다',emptyHint:'아래 버튼을 눌러 AI 회사를 시작하세요',emptyBtn:'＋ 새 회사 만들기',modalTitle:'🏢 새 회사 만들기',nameLabel:'회사명 / 프로젝트명',topicLabel:'주제 / 목표',langLabel:'언어 / Language',cancel:'취소',submit:'생성',orgTitle:'👥 조직',chatTitle:'💬 소통',taskTitle:'📌 작업',logTitle:'📋 로그',operating:'운영 중',chatPlaceholder:'@멘션으로 에이전트에게 지시',send:'전송',namePh:'예: O2O 마케팅 프로젝트',topicPh:'예: 온라인 비즈니스, 웹 서비스 개발...'},
  en: {newCompany:'New Company',createBtn:'＋ New Company',emptyTitle:'No companies yet',emptyHint:'Click below to start your first AI company',emptyBtn:'＋ Create Company',modalTitle:'🏢 Create New Company',nameLabel:'Company / Project Name',topicLabel:'Topic / Goal',langLabel:'Language',cancel:'Cancel',submit:'Create',orgTitle:'👥 Team',chatTitle:'💬 Chat',taskTitle:'📌 Tasks',logTitle:'📋 Log',operating:'Running',chatPlaceholder:'@mention an agent to instruct',send:'Send',namePh:'e.g. Marketing Campaign',topicPh:'e.g. E-commerce, Web Development...'},
